<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android 12+ (API 31+).
   cloud-backup: Google Drive backup/restore.
   device-transfer: device-to-device transfer (like Google Pixel setup).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
